PORT=3000
DATABASE_URL=postgresql://eudr:eudr_secret@localhost:5432/eudr

# Apache Doris OLAP warehouse
DORIS_HOST=localhost
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DATABASE=eudr_analytics
DORIS_SYNC_ON_START=true
WAREHOUSE_SYNC_INTERVAL_MS=300000

# Apache Superset BI
SUPERSET_URL=http://localhost:8088
SUPERSET_PUBLIC_ENABLED=false
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# Platform
JWT_SECRET=maaif-eudr-demo-secret-change-in-production
PUBLIC_USER_GUIDE_ENABLED=true

# Redis cache (optional locally; enabled by default in Docker)
REDIS_URL=redis://localhost:6379
# REDIS_ENABLED=false
CACHE_TTL_ANALYTICS=120
CACHE_TTL_GEO=3600
CACHE_TTL_CONFIG=300
CACHE_TTL_SUPPLY=60

# Remote access (set to your server public IP or hostname)
# Example: PUBLIC_BASE_URL=http://203.0.113.10:8003
PUBLIC_BASE_URL=
HOST=0.0.0.0

# Docker host port for API (nginx proxies here). Use 3001 if 3000 is taken (Grafana).
API_HOST_PORT=3000

# Docker host port for Superset (nginx /superset/ proxies here). Use 8089 if 8088 is taken.
SUPERSET_HOST_PORT=8088

# Superset path (relative — nginx proxies on same host:port as the platform)
SUPERSET_URL=/superset/login/

# AI Compliance Assistant (OpenAI-compatible + Gemini + DeepSeek)
AI_ASSISTANT_ENABLED=true
AI_DEFAULT_MODEL=gpt-4o-mini
AI_PRO_REQUIRES_AUTH=true
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# OPENAI_COMPAT_API_KEY=          # Any OpenAI-compatible API (LiteLLM, Ollama, Azure, etc.)
# OPENAI_COMPAT_BASE_URL=
# OPENAI_COMPAT_MODEL=
# AI_ALWAYS_SHOW_FALLBACK=true
# SERPER_API_KEY=                 # Optional — better web search (google.serper.dev)
