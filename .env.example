PORT=3000
DATABASE_URL=postgresql://eudr:eudr_secret@localhost:5432/eudr

# Apache Doris OLAP warehouse
DORIS_HOST=localhost
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DATABASE=eudr_analytics
DORIS_SYNC_ON_START=true
WAREHOUSE_SYNC_INTERVAL_MS=300000

# Apache Superset BI
SUPERSET_URL=http://localhost:8088
SUPERSET_PUBLIC_ENABLED=false
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# Platform
JWT_SECRET=maaif-eudr-demo-secret-change-in-production
PUBLIC_USER_GUIDE_ENABLED=true

# Remote access (set to your server public IP or hostname)
# Example: PUBLIC_BASE_URL=http://203.0.113.10:3000
PUBLIC_BASE_URL=
HOST=0.0.0.0

# Superset URL is auto-derived from PUBLIC_BASE_URL (port 8088) when left empty
SUPERSET_URL=
